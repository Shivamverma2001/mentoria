# =============================================================================
# Copy to .env and fill in secrets before running:
#   cp .env.example .env
#
# Local dev (uvicorn + npm run dev): use localhost URLs below.
# Docker Compose: compose overrides DATABASE_URL / REDIS_URL automatically.
# =============================================================================

# --- Required for matching (OpenAI) ---
OPENAI_API_KEY=sk-your-key-here

# --- Optional: Sentry observability ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.2

# --- Database (local dev; Docker uses postgres hostname) ---
DATABASE_URL=postgresql+asyncpg://arya:arya@localhost:5432/arya_jobs

# --- Redis (local dev; Docker uses redis hostname) ---
REDIS_URL=redis://localhost:6379/0

# --- LLM models ---
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini

# --- CORS (add origins your frontend uses) ---
# Local Vite: http://localhost:5173
# Docker frontend: http://localhost:3000
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Matcher tuning ---
SHORTLIST_SIZE=12
MATCH_CACHE_TTL_SECONDS=3600
RESUME_EMBEDDING_CACHE_TTL_SECONDS=86400
JOB_EMBEDDING_CACHE_TTL_SECONDS=604800
